extract only domain name
s="""https://www.example.com
http://test.org"""
import re  
pattern=r'https?://(www\.)?' #(www\.)? matches www. if it exists, otherwise ignores it
result=re.sub(pattern,'',s)   ## https? matches http or https
print(result)


Validate URLs and extract domain names
import re
text = """
https://www.example.com
http://test.org
https://sub.domain.co.in/path?x=1
invalid_url
"""

# Regex: validate + capture domain
pattern = re.compile(r'https?://(?:www\.)?([\w.-]+\.[a-zA-Z]{2,})')

matches = pattern.findall(text)
print(matches)
