extract email and phone number from raw api response as a string.

response = '{"user":"john","email":"john.doe@gmail.com","phone":"9876543210"}'
import re 
pattern=r'[\w.-]+@[\w.-]+\.[a-zA-Z]{2,3}'
res=re.findall(pattern,response)
print(res)

pattern1=r'[\+91]?\d{10}'
phone=re.findall(pattern1,response)
print(phone)

