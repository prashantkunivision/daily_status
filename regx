import re

log = """TEST PASS: login_test
TEST FAIL: payment_test
TEST PASS: search_test
TEST FAIL: checkout_test"""

pattern = re.compile(r'TEST FAIL:\s*(\w+)')     #(\w+) capturing Group ,[] Used to match any one character
failed_tests = pattern.findall(log)
print(failed_tests)

